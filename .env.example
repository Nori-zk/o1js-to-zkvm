# Succinct Prover Network credentials. Required when SP1_PROVER=network.
#
# Get a key at https://network.succinct.xyz (signs auction requests).
NETWORK_PRIVATE_KEY=0x...

# Optional. Defaults to the Succinct mainnet RPC endpoint.
# NETWORK_RPC_URL=https://rpc.mainnet.succinct.xyz

# Proof wrapping. Default = core (largest, cheapest). Use plonk/groth16 if
# you need an on-chain-verifiable wrapped proof.
# SP1_PROOF_TYPE=core

# --- Network mode knobs (all optional; SDK defaults are sensible) ---

# Which Succinct network: mainnet (auction-based) or reserved (hosted/reserved).
# SP1_NETWORK_MODE=mainnet

# How the request gets fulfilled: auction (default) | hosted | reserved.
# SP1_FULFILLMENT_STRATEGY=auction

# Max bid per bPGU (SDK default = 1_000_000_000 ≈ 1.0 PROVE).
# SP1_MAX_PRICE_PER_PGU=1000000000

# Request timeout in seconds (SDK default = 600).
# SP1_TIMEOUT_SECS=600

# Bypass simulation. If true, you must provide SP1_CYCLE_LIMIT/SP1_GAS_LIMIT
# (otherwise SDK uses network-mode-specific defaults). Off by default.
# SP1_SKIP_SIMULATION=false
# SP1_CYCLE_LIMIT=
# SP1_GAS_LIMIT=

# Restrict the auction to specific provers (comma-separated 0x… addresses).
# Empty/unset = SDK falls back to its default reliable-prover pool.
# SP1_WHITELIST=0xabc...,0xdef...
